<Window x:Class="InventoryApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт товарно-материальных ценностей"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB">

    <Grid>
        <!-- ── Два корневых столбца ───────────────────────────────── -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             ЛЕВЫЙ ГРИД — Категории (Column=0)
             ══════════════════════════════════════════════════════════ -->
        <Grid Column="0" Background="#1E3A5F">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#152D4A">
                <TextBlock Text="📦  ТМЦ Учёт"
                           Foreground="White"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="16,0"/>
            </Border>

            <!-- Метка -->
            <TextBlock Grid.Row="1" Text="КАТЕГОРИИ"
                       Foreground="#94A3B8"
                       FontSize="10" FontWeight="Bold"
                       Margin="16,12,0,6"/>

            <!-- Список категорий через ItemsControl -->
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="White">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="16,8"/>
                        <Setter Property="Foreground" Value="#CBD5E1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#253F5E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Кнопки фильтра -->
            <StackPanel Grid.Row="3" Margin="10,6,10,16">
                <Button Content="Фильтр по категории"
                        Command="{Binding FilterByCategoryCommand}"
                        Margin="0,0,0,6"/>
                <Button Content="Показать все"
                        Command="{Binding LoadAllCommand}"
                        Background="#374151"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             ПРАВЫЙ ГРИД — Основной (Column=1)
             ══════════════════════════════════════════════════════════ -->
        <Grid Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <!-- Панель инструментов -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <Button Content="➕ Добавить товар"
                            Command="{Binding AddProductCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="✏️ Редактировать"
                            Command="{Binding EditProductCommand}"
                            Margin="0,0,8,0"
                            Background="#10B981"/>
                    <Button Content="🗑 Удалить"
                            Command="{Binding DeleteProductCommand}"
                            Margin="0,0,16,0"
                            Background="#EF4444"/>
                    <Rectangle Width="1" Fill="#E5E7EB" Margin="0,8"/>
                    <Button Content="📦 Приход / Расход"
                            Command="{Binding AddMovementCommand}"
                            Margin="16,0,0,0"
                            Background="#8B5CF6"/>
                </StackPanel>
            </Border>

            <!-- Список товаров -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                      Margin="12,8,12,0"
                      Background="White"
                      BorderBrush="#E5E7EB">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название"  Width="220"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="SKU"       Width="110"
                                        DisplayMemberBinding="{Binding SKU}"/>
                        <GridViewColumn Header="Остаток"   Width="80"
                                        DisplayMemberBinding="{Binding Quantity}"/>
                        <GridViewColumn Header="Категория" Width="130"
                                        DisplayMemberBinding="{Binding Category.Name}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Разделитель + заголовок истории -->
            <Border Grid.Row="2" Background="#F1F5F9"
                    BorderBrush="#E5E7EB" BorderThickness="0,1,0,1"
                    Padding="12,6">
                <TextBlock Text="История движений товара"
                           FontWeight="SemiBold" FontSize="12"
                           Foreground="#475569"/>
            </Border>

            <!-- История движений через ItemsControl — ObservableCollection<StockMovement> -->
            <ListView Grid.Row="3"
                      ItemsSource="{Binding Movements}"
                      Margin="12,0,12,10"
                      Background="White"
                      BorderBrush="#E5E7EB">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Дата" Width="130"
                                        DisplayMemberBinding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}"/>
                        <GridViewColumn Header="Тип"  Width="60"
                                        DisplayMemberBinding="{Binding Type}"/>
                        <GridViewColumn Header="Кол-во" Width="70"
                                        DisplayMemberBinding="{Binding Quantity}"/>
                        <GridViewColumn Header="Товар"  Width="180"
                                        DisplayMemberBinding="{Binding Product.Name}"/>
                        <GridViewColumn Header="Комментарий" Width="220"
                                        DisplayMemberBinding="{Binding Comment}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>
